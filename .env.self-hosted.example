NODE_ENV=production
PORT=3001

# PostgreSQL
POSTGRES_DB=cutroom
POSTGRES_USER=cutroom
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://cutroom:change-me@postgres:5432/cutroom

# App access
BOOTSTRAP_SETUP_TOKEN=change-me-bootstrap-token
CORS_ORIGINS=
REQUIRE_API_ACCESS_KEY=false
API_ACCESS_KEY=
AUTH_COOKIE_SECURE=

# Storage/runtime
PROJECT_STORAGE_ADAPTER=local
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Optional binary overrides
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
